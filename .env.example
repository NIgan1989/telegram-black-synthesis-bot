# Порт для запуска локального сервера
PORT=3000

# Режим отладки / демо-режим (true для работы без реальных API ключей на фейковых данных)
DEMO_MODE=true

# Токен вашего Telegram-бота (полученный от @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Идентификатор Telegram-канала (например, @black_synthesis или числовой ID -100xxxxxxx)
TELEGRAM_CHANNEL_ID=your_telegram_channel_id_here

# Идентификатор вашего личного Telegram-аккаунта (для доступа в админку)
# Можно узнать через ботов вроде @userinfobot. Бот будет проверять этот ID при открытии Mini App
ADMIN_TELEGRAM_ID=your_personal_telegram_id_here

# (Опционально) Telegram username админа без @ — для deeplink "Написать админу" из бота
# Если не задан, бот использует tg://user?id=ADMIN_TELEGRAM_ID (работает не всегда)
ADMIN_TELEGRAM_USERNAME=A_Dula

# (Опционально) URL Mini App / админ-панели — для кнопок "Открыть админку" и "Заполнить заявку"
# В проде на Vercel: https://your-project.vercel.app
WEBAPP_URL=https://telegram-black-synthesis-bot.vercel.app

# Ключ Google Gemini API (для генерации постов ИИ и анализа тональности)
GEMINI_API_KEY=your_gemini_api_key_here

# Строка подключения к базе данных Supabase (для Vercel/продакшена)
# Оставьте пустой локально, чтобы использовать локальную SQLite базу
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:6543/postgres?pgbouncer=true

# Секретный ключ для вызова крон-задач на Vercel (чтобы посторонние не запускали парсинг)
CRON_SECRET=some_random_secure_string_here
